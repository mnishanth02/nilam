{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "outputs": [".next/**", "!.next/cache/**"],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.local", ".env.production.local"],
      "env": [
        "NEXT_PUBLIC_API_URL",
        "SENTRY_DSN",
        "NEXT_PUBLIC_SENTRY_DSN",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "DATABASE_URL"
      ]
    },
    "test": {
      "extends": false
    }
  }
}
