{
  "$schema": "https://turborepo.dev/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "env": [
        "DATABASE_URL",
        "TEST_DATABASE_URL",
        "S3_ENDPOINT",
        "S3_BUCKET",
        "S3_ACCESS_KEY",
        "S3_SECRET_KEY",
        "S3_REGION",
        "S3_FORCE_PATH_STYLE",
        "S3_PUBLIC_URL",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "RESEND_API_KEY",
        "RESEND_FROM_EMAIL",
        "INNGEST_EVENT_KEY",
        "INNGEST_SIGNING_KEY",
        "ENCRYPTION_SECRET",
        "CORS_ORIGIN",
        "SENTRY_DSN",
        "PORT"
      ]
    },
    "test": {
      "env": [
        "DATABASE_URL",
        "TEST_DATABASE_URL",
        "S3_ENDPOINT",
        "S3_BUCKET",
        "S3_ACCESS_KEY",
        "S3_SECRET_KEY",
        "S3_REGION",
        "S3_FORCE_PATH_STYLE",
        "S3_PUBLIC_URL",
        "BETTER_AUTH_SECRET",
        "BETTER_AUTH_URL",
        "RESEND_API_KEY",
        "RESEND_FROM_EMAIL",
        "INNGEST_EVENT_KEY",
        "INNGEST_SIGNING_KEY",
        "ENCRYPTION_SECRET",
        "CORS_ORIGIN",
        "SENTRY_DSN",
        "PORT"
      ]
    }
  }
}
